# ===== App =====
APP_NAME=rag-services
APP_ENV=dev
LOG_LEVEL=INFO
SECRET_KEY=change-me-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== Postgres =====
DATABASE_URL=postgresql+asyncpg://rag:rag_pass@localhost:5433/rag

# ===== Redis =====
REDIS_URL=redis://localhost:6380/0

# ===== Qdrant =====
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=kb_chunks

# ===== MinIO / S3 =====
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=rag-docs
S3_REGION=us-east-1

# ===== Embedding (local) =====
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIM=512

# ===== LLM (Aliyun DashScope / Qwen) =====
DASHSCOPE_API_KEY=sk-REPLACE-ME
# Leave DASHSCOPE_BASE_URL empty for default (mainland China).
# For international account use: https://dashscope-intl.aliyuncs.com
# Do NOT put compatible-mode/v1 here — that URL is only for OpenAI-compatible SDK.
DASHSCOPE_BASE_URL=
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=800
# Qwen3 family enables "thinking mode" by default; this slows TTFT by 10-30s.
# Keep True for low-latency customer service.
LLM_DISABLE_THINKING=true

# ===== Bootstrap admin =====
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin123456
