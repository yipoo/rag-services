# ===== App =====
APP_NAME=rag-services
APP_ENV=dev
LOG_LEVEL=INFO
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== Security =====
# Comma-separated list of allowed CORS origins. "*" is only allowed in dev.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Max upload size (bytes), 50MB default
MAX_UPLOAD_BYTES=52428800
ALLOWED_UPLOAD_EXTS=.pdf,.docx,.doc,.txt,.md,.markdown,.html,.htm
MAX_CSV_ROWS=5000
# Set true ONLY in dev to allow crawling private/loopback URLs
URL_CRAWL_ALLOW_PRIVATE=false
# Set true to skip startup safety checks (NOT recommended)
DISABLE_SAFETY_CHECKS=false

# ===== Postgres =====
DATABASE_URL=postgresql+asyncpg://rag:rag_pass@localhost:5433/rag

# ===== Redis =====
REDIS_URL=redis://localhost:6380/0

# ===== Qdrant =====
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=kb_chunks

# ===== MinIO / S3 =====
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=rag-docs
S3_REGION=us-east-1

# ===== Embedding (local) =====
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIM=512

# ===== LLM (local Ollama / DeepSeek R1) =====
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=deepseek-r1:7b
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=800
LLM_DISABLE_THINKING=false

# ===== Bootstrap admin =====
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin123456
